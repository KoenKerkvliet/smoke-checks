# Kopieer naar .env voor lokaal draaien met Supabase-upload.
# Zonder deze vars draait de runner ook — dan alleen lokale results/latest.json.

SUPABASE_URL=https://xxxxx.supabase.co
# LET OP: service-key = geheim. Alleen lokaal in .env of als GitHub Actions secret.
SUPABASE_SERVICE_KEY=

# Optioneel: alleen één site draaien (slug uit sites/*.json)
# SITE_FILTER=tvrapid
